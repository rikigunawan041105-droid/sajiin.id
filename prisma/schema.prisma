generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/dev.db"
}

model Food {
  id            String   @id @default(cuid())
  food_id       String   @unique
  name          String
  price         Int
  category      String
  image         String
  rating        Float
  description   String
  composition   String
  spiciness     Int      @default(0)
  stock         Int      @default(0)
  available     Boolean  @default(true)
  pre_order_time String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id               String      @id @default(cuid())
  order_number     Int         @unique
  customer_name    String
  customer_whatsapp String
  date             String
  time             String
  notes            String?
  total_price      Int
  payment_method   String
  status           String      @default("Pending")
  items            OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model OrderItem {
  id       String @id @default(cuid())
  order_id String
  order    Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  food_id  String
  name     String
  price    Int
  quantity Int
}

model Outlet {
  id               Int     @id @default(autoincrement())
  name             String
  address          String
  city             String
  phone            String?
  email            String?
  google_maps_link String?
  is_main          Boolean @default(false)
}

model SocialMedia {
  id       Int     @id @default(autoincrement())
  platform String
  url      String
  icon     String?
}

model BusinessHour {
  id         Int    @id @default(autoincrement())
  day_group  String
  label      String
  open_time  String
  close_time String
}

model Admin {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String @default("admin")
}
